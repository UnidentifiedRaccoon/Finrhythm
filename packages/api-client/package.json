{
  "name": "@finrhythm/api-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./openapi": {
      "default": "./openapi/finrhythm-api.openapi.json"
    }
  },
  "files": [
    "dist",
    "openapi",
    "src/generated"
  ],
  "scripts": {
    "build": "pnpm run generate && tsc -p tsconfig.json",
    "check:generated": "node scripts/generate-contracts.mjs --check",
    "check:openapi-drift": "node scripts/check-openapi-drift.mjs",
    "generate": "node scripts/generate-contracts.mjs",
    "test": "pnpm run check:generated && pnpm run check:openapi-drift",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
