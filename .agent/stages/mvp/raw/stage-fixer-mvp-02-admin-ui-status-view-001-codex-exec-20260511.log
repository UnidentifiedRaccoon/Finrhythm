              <td>
                <span className={`status-badge status-${row.status.toLowerCase()}`}>
                  {STATUS_LABELS[row.status]}
                </span>
              </td>
              <td>{formatDate(row.issuedAt)}</td>
              <td>{formatDate(row.expiresAt)}</td>
